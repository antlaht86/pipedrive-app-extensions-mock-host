{
  "name": "pipedrive-app-extensions-mock-host",
  "version": "0.3.1",
  "description": "Development-only mock host for the Pipedrive App Extensions SDK: lets your app extension's code run on localhost — talking to the real @pipedrive/app-extensions-sdk — by playing the Pipedrive window and rendering real UI elements. Framework-agnostic.",
  "keywords": [
    "pipedrive",
    "app-extensions",
    "sdk",
    "mock",
    "mock-host",
    "testing",
    "ui",
    "development"
  ],
  "homepage": "https://github.com/antlaht86/pipedrive-app-extensions-mock-host#readme",
  "bugs": {
    "url": "https://github.com/antlaht86/pipedrive-app-extensions-mock-host/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antlaht86/pipedrive-app-extensions-mock-host.git"
  },
  "author": "antlaht86 <antti.lahtinen@zimple.fi>",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.global.js",
  "jsdelivr": "./dist/index.global.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "vitest",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:browser": "vitest run --project browser",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "ci": "npm run build && npm run typecheck && npm run check-format && npm run test",
    "local-release": "changeset version && changeset publish",
    "prepublishOnly": "npm run build && npm run typecheck && npm run check-format && npm run test:unit"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@pipedrive/app-extensions-sdk": ">=0.16.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@pipedrive/app-extensions-sdk": "^0.16.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.3",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
