{
  "name": "pipedrive-app-extensions-sdk-mock",
  "version": "0.0.0",
  "description": "Framework-agnostic mock of the Pipedrive App Extensions SDK that renders real UI elements, for local development and testing without running inside Pipedrive.",
  "keywords": [
    "pipedrive",
    "app-extensions",
    "sdk",
    "mock",
    "stub",
    "testing",
    "ui"
  ],
  "homepage": "https://github.com/antlaht86/pipedrive-app-extensions-sdk-mock#readme",
  "bugs": {
    "url": "https://github.com/antlaht86/pipedrive-app-extensions-sdk-mock/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antlaht86/pipedrive-app-extensions-sdk-mock.git"
  },
  "author": "antlaht86 <antti.lahtinen@zimple.fi>",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "dev": "vitest",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:browser": "vitest run --project browser",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "ci": "npm run build && npm run check-format && npm run test",
    "local-release": "changeset version && changeset publish",
    "prepublishOnly": "npm run ci"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@pipedrive/app-extensions-sdk": "^0.16.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.3",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
